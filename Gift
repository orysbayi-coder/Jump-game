<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<title>Сыйлық ойыны</title>

<style>
body{
font-family: Arial;
background:#1e293b;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
color:white;
}

.grid{
display:grid;
grid-template-columns:repeat(3,120px);
gap:20px;
}

.gift{
width:120px;
height:120px;
font-size:50px;
background:#334155;
border:none;
border-radius:15px;
cursor:pointer;
}

.open{
background:#0f172a;
font-size:40px;
}
</style>

</head>
<body>

<div class="grid">

<button class="gift" onclick="openGift(this)">🎁</button>
<button class="gift" onclick="openGift(this)">🎁</button>
<button class="gift" onclick="openGift(this)">🎁</button>

<button class="gift" onclick="openGift(this)">🎁</button>
<button class="gift" onclick="openGift(this)">🎁</button>
<button class="gift" onclick="openGift(this)">🎁</button>

<button class="gift" onclick="openGift(this)">🎁</button>
<button class="gift" onclick="openGift(this)">🎁</button>
<button class="gift" onclick="openGift(this)">🎁</button>

</div>

<script>

function openGift(btn){

btn.innerHTML = "📦"
btn.classList.add("open")

}

</script>

</body>
</html>
