<!doctype html>
<html lang="kk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Flappy Day — 999 Win</title>
  <style>
    html,body{height:100%;margin:0;background:#eaf4ff;color:#0b1220;font-family:system-ui,Segoe UI,Arial}
    .wrap{display:grid;place-items:center;height:100%}
    canvas{
      border-radius:18px;
      border:1px solid rgba(0,0,0,.12);
      box-shadow:0 30px 120px rgba(0,0,0,.20);
      touch-action:manipulation;
      background:#fff;
    }
    .hint{
      max-width:820px;text-align:center;margin-top:12px;color:#3b4a66;font-size:14px;line-height:1.35
    }
    .kbd{display:inline-block;padding:2px 8px;border:1px solid rgba(0,0,0,.15);border-radius:9px;background:rgba(0,0,0,.04)}
  </style>
</head>
<body>
  <div class="wrap">
    <div>
      <canvas id="c" width="420" height="720"></canvas>
      <div class="hint">
        Басқару: <span class="kbd">Space</span> немесе <span class="kbd">Click/Tap</span> — секіру.
        <span class="kbd">R</span> — қайта бастау.
        Ұпай: құбыр +1, 🪙 монета +2, ⭐ жұлдыз +5. Жеңіс: <b>999 ұпай</b>.
      </div>
    </div>
  </div>

<script>
(() => {
  const canvas = document.getElementById('c');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;

  // ===== Win condition =====
  const WIN_SCORE = 999;

  // ===== Difficulty (single mode) =====
  // Over time: speed slowly increases, gap slowly decreases (bounded).
  const base = {
    pipeSpeed: 2.7,
    gap: 178,
    gravity: 0.44,
    spawn: 1420
  };

  // ===== State =====
  let score = 0, best = 0;
  let running = false, gameOver = false, win = false;

  let pipes = [];
  let items = []; // coin/star
  let lastSpawn = 0;
  let t = 0;

  // Bird
  const bird = {
    x: 112,
    y: H * 0.45,
    r: 14,
    vy: 0,
    flap: -8.15,
    tilt: 0
  };

  function rand(a,b){ return a + Math.random()*(b-a); }

  function reset(){
    pipes = [];
    items = [];
    bird.y = H * 0.45;
    bird.vy = 0;
    bird.tilt = 0;

    score = 0;
    lastSpawn = performance.now();
    gameOver = false;
    win = false;
    running = false; // show start overlay
  }

  // Difficulty curve based on score (0..999)
  function diff(){
    // progress 0..1
    const p = Math.min(1, score / WIN_SCORE);

    // speed increases up to +2.2
    const pipeSpeed = base.pipeSpeed + 2.2 * p;

    // gap decreases to min 132
    const gap = Math.max(132, base.gap - 52 * p);

    // gravity slightly increases
    const gravity = base.gravity + 0.08 * p;

    // spawn interval slightly faster
    const spawn = Math.max(1120, base.spawn - 240 * p);

    return { pipeSpeed, gap, gravity, spawn };
  }

  function spawnPipeAndItems(){
    const D = diff();
    const gap = D.gap;

    const margin = 95;
    const center = rand(margin + gap/2, H - margin - gap/2);
    const topH = center - gap/2;
    const botY = center + gap/2;

    const pipeX = W + 60;
    const pipe = { x: pipeX, w: 74, topH, botY, passed:false };
    pipes.push(pipe);

    // Items: 0..2 in the gap
    const count = (Math.random() < 0.32) ? 2 : (Math.random() < 0.78 ? 1 : 0);
    for (let i=0;i<count;i++){
      const type = (Math.random() < 0.16) ? "star" : "coin";
      const y = rand(topH + 32, botY - 32);
      const x = pipeX + rand(15, 120);
      const r = type === "star" ? 12 : 10;
      items.push({ type, x, y, r, alive:true, ph: Math.random()*Math.PI*2 });
    }
  }

  // Collisions
  function circleRectCollide(cx, cy, cr, rx, ry, rw, rh) {
    const nx = Math.max(rx, Math.min(cx, rx + rw));
    const ny = Math.max(ry, Math.min(cy, ry + rh));
    const dx = cx - nx, dy = cy - ny;
    return (dx*dx + dy*dy) <= cr*cr;
  }
  function circleCircle(cx,cy,cr, x,y,r){
    const dx=cx-x, dy=cy-y;
    return dx*dx+dy*dy <= (cr+r)*(cr+r);
  }

  // Input
  function flap(){
    if (win) return;
    if (gameOver){
      // restart
      pipes = [];
      items = [];
      bird.y = H*0.45;
      bird.vy = 0;
      lastSpawn = performance.now();
      score = 0;
      gameOver = false;
      running = true;
      return;
    }
    if (!running) running = true;
    bird.vy = bird.flap;
  }

  window.addEventListener('keydown', (e) => {
    if (e.code === 'Space') { e.preventDefault(); flap(); }
    if (e.key.toLowerCase() === 'r') { reset(); }
  });
  canvas.addEventListener('pointerdown', flap);

  function addScore(v){
    score += v;
    if (score > WIN_SCORE) score = WIN_SCORE;
    best = Math.max(best, score);
    if (score >= WIN_SCORE){
      win = true;
      running = false;
    }
  }

  // Update
  function update(dt){
    const D = diff();

    bird.vy += D.gravity;
    bird.y += bird.vy;
    bird.tilt = Math.max(-0.55, Math.min(0.95, bird.vy / 12));

    // bounds
    if (bird.y - bird.r < 0) { bird.y = bird.r; bird.vy = 0; }
    if (bird.y + bird.r > H) {
      bird.y = H - bird.r;
      gameOver = true;
      running = false;
    }

    // spawn
    const now = performance.now();
    if (now - lastSpawn > D.spawn) {
      spawnPipeAndItems();
      lastSpawn = now;
    }

    // move pipes/items
    for (const p of pipes) p.x -= D.pipeSpeed;
    pipes = pipes.filter(p => p.x + p.w > -140);

    for (const it of items){
      it.x -= D.pipeSpeed;
      it.ph += dt * 4.2;
      it.y += Math.sin(it.ph) * 0.25;
    }
    items = items.filter(it => it.alive && it.x > -140);

    // pipe collision + pass score
    for (const p of pipes) {
      const topRect = { x:p.x, y:0, w:p.w, h:p.topH };
      const botRect = { x:p.x, y:p.botY, w:p.w, h:H - p.botY };

      if (circleRectCollide(bird.x, bird.y, bird.r, topRect.x, topRect.y, topRect.w, topRect.h) ||
          circleRectCollide(bird.x, bird.y, bird.r, botRect.x, botRect.y, botRect.w, botRect.h)) {
        gameOver = true;
        running = false;
      }

      if (!p.passed && p.x + p.w < bird.x) {
        p.passed = true;
        addScore(1);
      }
    }

    // collect items
    for (const it of items){
      if (!it.alive) continue;
      if (circleCircle(bird.x, bird.y, bird.r, it.x, it.y, it.r)) {
        it.alive = false;
        addScore(it.type === "coin" ? 2 : 5);
      }
    }

    t += dt;
  }

  // ===== Drawing: DAY graphics =====
  function draw(){
    ctx.clearRect(0,0,W,H);

    drawSky();
    drawSun();
    drawClouds();
    drawHills();
    drawGroundStrip();

    // pipes
    for (const p of pipes){
      drawPipe(p.x, 0, p.w, p.topH, true);
      drawPipe(p.x, p.botY, p.w, H - p.botY, false);
    }

    // items
    for (const it of items){
      if (!it.alive) continue;
      if (it.type === "coin") drawCoin(it.x, it.y, it.r);
      else drawStar(it.x, it.y, it.r);
    }

    // bird
    drawBird(bird.x, bird.y, bird.r, bird.tilt);

    // hud
    drawHUD();

    // overlays
    if (win) overlay("ЖЕҢІС! 🏆", `999 ұпайға жеттің! R — қайта бастау`);
    else if (!running && !gameOver && score === 0 && pipes.length === 0) {
      overlay("Flappy Day", "Space / Click — бастау");
    } else if (gameOver) {
      overlay("Ойын бітті 💥", "Space — қайта ойнау, R — қайта бастау");
    }
  }

  function drawSky(){
    const g = ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0, "#8fd3ff");
    g.addColorStop(0.55, "#c9eeff");
    g.addColorStop(1, "#eaf7ff");
    ctx.fillStyle = g;
    ctx.fillRect(0,0,W,H);
  }

  function drawSun(){
    const x = W*0.78, y = H*0.16;
    ctx.save();
    ctx.globalAlpha = 0.35;
    ctx.fillStyle = "#fff3b0";
    ctx.beginPath(); ctx.arc(x,y,55,0,Math.PI*2); ctx.fill();
    ctx.globalAlpha = 0.9;
    ctx.fillStyle = "#ffe16a";
    ctx.beginPath(); ctx.arc(x,y,28,0,Math.PI*2); ctx.fill();
    ctx.restore();
  }

  function drawClouds(){
    // parallax clouds
    const baseY = 120;
    for (let layer=0; layer<3; layer++){
      const speed = 18 + layer*26;
      const alpha = 0.55 - layer*0.12;
      const y = baseY + layer*55;
      for (let i=0;i<4;i++){
        const x = ((i*170) - (t*speed*6) % (W+220)) + 40;
        cloud(W - x, y + (i%2)*10, 1.0 - layer*0.12, alpha);
      }
    }
  }

  function cloud(x,y,scale,alpha){
    ctx.save();
    ctx.globalAlpha = alpha;
    ctx.fillStyle = "#ffffff";
    ctx.beginPath();
    ctx.ellipse(x, y, 34*scale, 22*scale, 0, 0, Math.PI*2);
    ctx.ellipse(x+26*scale, y+4*scale, 30*scale, 20*scale, 0, 0, Math.PI*2);
    ctx.ellipse(x-26*scale, y+6*scale, 26*scale, 18*scale, 0, 0, Math.PI*2);
    ctx.ellipse(x+6*scale, y-10*scale, 24*scale, 16*scale, 0, 0, Math.PI*2);
    ctx.closePath();
    ctx.fill();
    ctx.restore();
  }

  function drawHills(){
    // distant hills
    ctx.globalAlpha = 0.65;
    ctx.fillStyle = "#6fd39b";
    hillPath(0.55, H-150, 22);
    ctx.globalAlpha = 0.85;
    ctx.fillStyle = "#3bcf86";
    hillPath(0.75, H-110, 18);
    ctx.globalAlpha = 1;
  }

  function hillPath(freq, baseY, amp){
    ctx.beginPath();
    ctx.moveTo(0, H);
    for (let x=0; x<=W; x+=16){
      const y = baseY + Math.sin((x*0.01)*freq + t*0.8) * amp;
      ctx.lineTo(x,y);
    }
    ctx.lineTo(W,H);
    ctx.closePath();
    ctx.fill();
  }

  function drawGroundStrip(){
    const gh = 78;
    ctx.fillStyle = "rgba(0,0,0,.06)";
    ctx.fillRect(0, H-gh, W, gh);

    // grass line
    ctx.strokeStyle = "rgba(0,0,0,.10)";
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(0, H-gh);
    ctx.lineTo(W, H-gh);
    ctx.stroke();
  }

  function drawPipe(x,y,w,h,isTop){
    // day pipe: glossy green
    const g = ctx.createLinearGradient(x,y,x+w,y+h);
    g.addColorStop(0, "rgba(30,190,120,.95)");
    g.addColorStop(1, "rgba(10,140,85,.98)");
    ctx.fillStyle = g;
    roundRect(x,y,w,h,14,true,false);

    // highlight
    ctx.globalAlpha = 0.35;
    ctx.fillStyle = "#ffffff";
    roundRect(x+10, y+8, 10, Math.max(14,h-16), 8, true, false);
    ctx.globalAlpha = 1;

    // border
    ctx.strokeStyle = "rgba(0,0,0,.18)";
    ctx.lineWidth = 2;
    roundRect(x+1,y+1,w-2,h-2,13,false,true);

    // lip/cap
    const lipH = 16;
    const capY = isTop ? (y + h - lipH) : y;
    const capG = ctx.createLinearGradient(x-8,capY,x+w+8,capY+lipH);
    capG.addColorStop(0,"rgba(80,240,170,.85)");
    capG.addColorStop(1,"rgba(25,170,110,.9)");
    ctx.fillStyle = capG;
    roundRect(x-8, capY, w+16, lipH, 10, true, false);
    ctx.strokeStyle = "rgba(0,0,0,.14)";
    ctx.lineWidth = 2;
    roundRect(x-8+1, capY+1, w+16-2, lipH-2, 9, false, true);
  }

  function drawCoin(x,y,r){
    ctx.save();
    ctx.shadowBlur = 14;
    ctx.shadowColor = "rgba(255,190,40,.45)";
    const cg = ctx.createRadialGradient(x-r*0.3,y-r*0.3,2, x,y,r*1.2);
    cg.addColorStop(0,"rgba(255,250,210,.95)");
    cg.addColorStop(0.6,"rgba(255,200,70,.85)");
    cg.addColorStop(1,"rgba(255,200,70,.05)");
    ctx.fillStyle = cg;
    ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fill();
    ctx.restore();

    ctx.strokeStyle = "rgba(120,70,10,.35)";
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(x,y,r-1,0,Math.PI*2); ctx.stroke();
  }

  function drawStar(x,y,r){
    ctx.save();
    ctx.shadowBlur = 16;
    ctx.shadowColor = "rgba(60,170,255,.35)";
    ctx.fillStyle = "rgba(255,255,255,.92)";
    ctx.beginPath();
    const spikes = 5;
    const outer = r, inner = r*0.45;
    let rot = -Math.PI/2;
    const step = Math.PI/spikes;
    ctx.moveTo(x + Math.cos(rot)*outer, y + Math.sin(rot)*outer);
    for (let i=0;i<spikes;i++){
      ctx.lineTo(x + Math.cos(rot+step)*inner, y + Math.sin(rot+step)*inner);
      ctx.lineTo(x + Math.cos(rot+2*step)*outer, y + Math.sin(rot+2*step)*outer);
      rot += 2*step;
    }
    ctx.closePath();
    ctx.fill();
    ctx.restore();

    ctx.globalAlpha = 0.65;
    ctx.strokeStyle = "rgba(60,170,255,.55)";
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function drawBird(x,y,r,tilt){
    ctx.save();
    ctx.translate(x,y);
    ctx.rotate(tilt);

    // body
    const bg = ctx.createLinearGradient(-r,-r,r,r);
    bg.addColorStop(0,"rgba(255,255,255,.98)");
    bg.addColorStop(0.55,"rgba(160,210,255,.92)");
    bg.addColorStop(1,"rgba(90,160,255,.88)");
    ctx.fillStyle = bg;

    ctx.beginPath();
    ctx.ellipse(0,0,r*1.06,r*0.92,0,0,Math.PI*2);
    ctx.fill();

    ctx.strokeStyle = "rgba(0,0,0,.22)";
    ctx.lineWidth = 2;
    ctx.stroke();

    // wing
    ctx.globalAlpha = 0.75;
    ctx.fillStyle = "rgba(0,0,0,.12)";
    ctx.beginPath();
    ctx.ellipse(-4, 4, r*0.55, r*0.35, -0.4, 0, Math.PI*2);
    ctx.fill();
    ctx.globalAlpha = 1;

    // eye
    ctx.fillStyle = "rgba(0,0,0,.55)";
    ctx.beginPath(); ctx.arc(r*0.25,-r*0.18,3.2,0,Math.PI*2); ctx.fill();

    // beak
    ctx.fillStyle = "rgba(255,190,40,.92)";
    ctx.beginPath();
    ctx.moveTo(r*0.9, 1);
    ctx.lineTo(r*1.55, -3);
    ctx.lineTo(r*1.55, 5);
    ctx.closePath();
    ctx.fill();
    ctx.strokeStyle = "rgba(0,0,0,.18)";
    ctx.stroke();

    ctx.restore();
  }

  function drawHUD(){
    // glass panel
    ctx.save();
    ctx.globalAlpha = 0.88;
    ctx.fillStyle = "rgba(255,255,255,.55)";
    roundRect(10, 10, W-20, 58, 14, true, false);

    ctx.strokeStyle = "rgba(0,0,0,.10)";
    ctx.lineWidth = 2;
    roundRect(10, 10, W-20, 58, 14, false, true);

    ctx.globalAlpha = 1;
    ctx.fillStyle = "rgba(10,20,40,.92)";
    ctx.font = "800 16px system-ui, Segoe UI, Arial";
    ctx.fillText(`Ұпай: ${score} / ${WIN_SCORE}`, 22, 34);

    ctx.fillStyle = "rgba(10,20,40,.65)";
    ctx.font = "14px system-ui, Segoe UI, Arial";
    ctx.fillText(`🪙 +2  •  ⭐ +5  •  Құбыр +1`, 22, 56);

    ctx.textAlign = "right";
    ctx.fillStyle = "rgba(10,20,40,.75)";
    ctx.font = "14px system-ui, Segoe UI, Arial";
    ctx.fillText(`Best: ${best}`, W-22, 34);

    // progress bar
    const barX = W-160, barY = 44, barW = 140, barH = 10;
    ctx.globalAlpha = 0.65;
    ctx.fillStyle = "rgba(0,0,0,.12)";
    roundRect(barX, barY, barW, barH, 8, true, false);
    ctx.globalAlpha = 1;
    const p = score / WIN_SCORE;
    ctx.fillStyle = "rgba(40,160,255,.75)";
    roundRect(barX, barY, Math.max(8, barW*p), barH, 8, true, false);

    ctx.textAlign = "left";
    ctx.restore();
  }

  function overlay(title, subtitle){
    ctx.save();
    ctx.fillStyle = "rgba(255,255,255,.35)";
    ctx.fillRect(0,0,W,H);

    // card
    ctx.globalAlpha = 0.92;
    ctx.fillStyle = "rgba(255,255,255,.72)";
    roundRect(38, H/2-112, W-76, 224, 22, true, false);
    ctx.globalAlpha = 1;

    ctx.strokeStyle = "rgba(0,0,0,.12)";
    ctx.lineWidth = 2;
    roundRect(38, H/2-112, W-76, 224, 22, false, true);

    ctx.fillStyle = "rgba(10,20,40,.92)";
    ctx.font = "900 34px system-ui, Segoe UI, Arial";
    ctx.textAlign = "center";
    ctx.fillText(title, W/2, H/2 - 22);

    ctx.fillStyle = "rgba(10,20,40,.70)";
    ctx.font = "16px system-ui, Segoe UI, Arial";
    ctx.fillText(subtitle, W/2, H/2 + 16);

    ctx.fillStyle = "rgba(10,20,40,.60)";
    ctx.font = "13px system-ui, Segoe UI, Arial";
    ctx.fillText("Space/Click — ойнау", W/2, H/2 + 50);

    ctx.textAlign = "left";
    ctx.restore();
  }

  function roundRect(x,y,w,h,r,fill,stroke){
    const rr = Math.min(r, w/2, h/2);
    ctx.beginPath();
    ctx.moveTo(x+rr,y);
    ctx.arcTo(x+w,y, x+w,y+h, rr);
    ctx.arcTo(x+w,y+h, x,y+h, rr);
    ctx.arcTo(x,y+h, x,y, rr);
    ctx.arcTo(x,y, x+w,y, rr);
    ctx.closePath();
    if (fill) ctx.fill();
    if (stroke) ctx.stroke();
  }

  // Main loop
  let last = performance.now();
  function loop(now){
    const dt = Math.min(0.03, (now-last)/1000);
    last = now;

    if (running && !gameOver && !win) update(dt);
    draw();
    requestAnimationFrame(loop);
  }

  reset();
  requestAnimationFrame(loop);
})();
</script>
</body>
</html>
