<!DOCTYPE html>
<html lang="kk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>9 Сыйлық — бәрі бос</title>
  <style>
    body{
      font-family: system-ui, Arial, sans-serif;
      background:#0f172a;
      color:#e2e8f0;
      margin:0;
      display:flex;
      min-height:100vh;
      align-items:center;
      justify-content:center;
    }
    .wrap{
      width:min(720px, 92vw);
      text-align:center;
    }
    h1{ margin:0 0 10px; font-size:28px; }
    p{ margin:0 0 18px; opacity:.9; }

    .grid{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap:14px;
      margin: 18px 0;
    }
    button.gift{
      border:0;
      border-radius:18px;
      padding:18px 10px;
      background: linear-gradient(180deg, #334155, #1e293b);
      color:#e2e8f0;
      cursor:pointer;
      box-shadow: 0 10px 25px rgba(0,0,0,.25);
      transition: transform .08s ease, filter .2s ease;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      min-height:110px;
      user-select:none;
    }
    button.gift:hover{ filter:brightness(1.08); }
    button.gift:active{ transform: scale(0.98); }

    .emoji{ font-size:36px; line-height:1; }
    .label{ margin-top:8px; font-weight:600; }

    .msg{
      margin-top:10px;
      padding:12px 14px;
      border-radius:14px;
      background: rgba(148,163,184,.12);
      border: 1px solid rgba(148,163,184,.25);
      min-height:46px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:18px;
    }

    .row{
      display:flex;
      gap:10px;
      justify-content:center;
      margin-top:12px;
      flex-wrap:wrap;
    }
    .smallbtn{
      border:0;
      border-radius:12px;
      padding:10px 14px;
      background:#2563eb;
      color:white;
      cursor:pointer;
      font-weight:600;
    }
    .smallbtn.secondary{
      background:#475569;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>🎁 9 сыйлық</h1>
    <p>Кез келген сыйлықты бас — бәрі бос 🙂</p>

    <div class="grid" id="grid"></div>

    <div class="msg" id="msg">Бастау үшін кез келген сыйлықты бас.</div>

    <div class="row">
      <button class="smallbtn secondary" id="reset">Қайта бастау</button>
      <button class="smallbtn" id="revealAll">Барлығын тексеру</button>
    </div>
  </div>

  <script>
    const grid = document.getElementById("grid");
    const msg = document.getElementById("msg");
    const resetBtn = document.getElementById("reset");
    const revealAllBtn = document.getElementById("revealAll");

    let clicks = 0;

    function setMessage(text){
      msg.textContent = text;
    }

    function createGifts(){
      grid.innerHTML = "";
      clicks = 0;
      setMessage("Бастау үшін кез келген сыйлықты бас.");

      for(let i=1;i<=9;i++){
        const btn = document.createElement("button");
        btn.className = "gift";
        btn.innerHTML = `
          <div class="emoji">🎁</div>
          <div class="label">Сыйлық ${i}</div>
        `;

        btn.addEventListener("click", () => {
          clicks++;
          // бәрі БОС болуы керек:
          setMessage(`Сыйлық ${i}: Бос 🎁 (ештеңе жоқ). Басулар саны: ${clicks}`);
        });

        grid.appendChild(btn);
      }
    }

    resetBtn.addEventListener("click", createGifts);

    revealAllBtn.addEventListener("click", () => {
      setMessage("Нәтиже: 9/9 — бәрі бос ✅");
    });

    createGifts();
  </script>
</body>
</html>
