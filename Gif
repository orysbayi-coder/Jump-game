<!DOCTYPE html>
<html lang="kk">
<head>
<meta charset="UTF-8">
<title>Сыйлық ойыны</title>

<style>
body{
font-family:Arial;
background:#1e293b;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
height:100vh;
color:white;
}

.grid{
display:grid;
grid-template-columns:repeat(3,120px);
gap:20px;
margin-bottom:20px;
}

.gift{
width:120px;
height:120px;
font-size:50px;
background:#334155;
border:none;
border-radius:15px;
cursor:pointer;
}

.open{
background:#0f172a;
}

#reset{
padding:10px 20px;
font-size:16px;
border:none;
border-radius:10px;
background:#2563eb;
color:white;
cursor:pointer;
display:none;
}
</style>

</head>
<body>

<div class="grid" id="grid"></div>

<button id="reset" onclick="resetGame()">Қайта көру</button>

<script>

let opened = 0
const grid = document.getElementById("grid")

function createGifts(){

grid.innerHTML = ""
opened = 0
document.getElementById("reset").style.display="none"

for(let i=0;i<9;i++){

let btn = document.createElement("button")
btn.className="gift"
btn.innerHTML="🎁"

btn.onclick=function(){

if(opened >=3) return

btn.innerHTML="📦"
btn.classList.add("open")
btn.disabled=true

opened++

if(opened==3){
document.getElementById("reset").style.display="block"
}

}

grid.appendChild(btn)

}

}

function resetGame(){
createGifts()
}

createGifts()

</script>

</body>
</html>
