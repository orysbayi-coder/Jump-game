<!doctype html>
<html lang="kk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Red Light / Green Light (Original)</title>
  <style>
    html,body{height:100%;margin:0;font-family:system-ui,Segoe UI,Arial;background:#0b1220;color:#e7ecff}
    .wrap{display:grid;place-items:center;height:100%}
    canvas{border-radius:16px;border:1px solid rgba(255,255,255,.14);box-shadow:0 30px 120px rgba(0,0,0,.45);background:#0f1730}
    .hint{max-width:820px;text-align:center;margin-top:12px;color:#aab6e6;font-size:14px;line-height:1.35}
    .kbd{display:inline-block;padding:2px 8px;border:1px solid rgba(255,255,255,.2);border-radius:9px;background:rgba(255,255,255,.06)}
  </style>
</head>
<body>
<div class="wrap">
  <div>
    <canvas id="c" width="720" height="420"></canvas>
    <div class="hint">
      Басқару: <span class="kbd">WASD</span> немесе <span class="kbd">↑↓←→</span> — жүру.
      Ереже: <b>GREEN</b> кезінде жүр, <b>RED</b> кезінде қозғалсаң — ұтыласың.
      <span class="kbd">R</span> — қайта бастау.
    </div>
  </div>
</div>

<script>
(() => {
  const c = document.getElementById('c');
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;

  // Game parameters
  const START = { x: 70, y: H/2 };
  const FINISH_X = W - 90;

  let state = "start"; // start, play, lose, win
  let light = "green"; // green, red
  let nextSwitch = 0;
  let t = 0;

  // Player
  const p = { x: START.x, y: START.y, r: 14, vx:0, vy:0, speed: 170, movedThisFrame:false };

  // Input
  const keys = new Set();
  window.addEventListener('keydown', e => {
    keys.add(e.key.toLowerCase());
    if (e.key.toLowerCase() === 'r') reset();
    if (e.code === 'Space' && state === 'start') state = "play";
  });
  window.addEventListener('keyup', e => keys.delete(e.key.toLowerCase()));

  function reset(){
    state = "start";
    light = "green";
    nextSwitch = performance.now() + randSwitch();
    p.x = START.x; p.y = START.y; p.vx = 0; p.vy = 0;
  }

  function randSwitch(){
    // green lasts 1.4-2.6s, red lasts 0.9-1.8s
    if (light === "green") return rand(900, 1800);
    return rand(1400, 2600);
  }

  function rand(a,b){ return a + Math.random()*(b-a); }
  function clamp(v,a,b){ return Math.max(a, Math.min(b, v)); }

  function update(dt){
    const now = performance.now();

    // switch light
    if (now > nextSwitch){
      light = (light === "green") ? "red" : "green";
      nextSwitch = now + randSwitch();
    }

    // movement
    let dx = 0, dy = 0;
    if (keys.has('arrowleft') || keys.has('a')) dx -= 1;
    if (keys.has('arrowright') || keys.has('d')) dx += 1;
    if (keys.has('arrowup') || keys.has('w')) dy -= 1;
    if (keys.has('arrowdown') || keys.has('s')) dy += 1;

    const len = Math.hypot(dx,dy) || 1;
    dx/=len; dy/=len;

    const moving = (Math.abs(dx)+Math.abs(dy)) > 0.001;
    p.movedThisFrame = moving;

    p.vx = dx * p.speed;
    p.vy = dy * p.speed;

    p.x += p.vx * dt;
    p.y += p.vy * dt;

    // bounds
    p.x = clamp(p.x, 30, W-30);
    p.y = clamp(p.y, 40, H-40);

    // rule: moved during red = lose (small tolerance: must be actually moving)
    if (light === "red" && moving){
      state = "lose";
    }

    // win
    if (p.x >= FINISH_X){
      state = "win";
    }
  }

  function draw(){
    ctx.clearRect(0,0,W,H);

    // background
    const g = ctx.createLinearGradient(0,0,0,H);
    g.addColorStop(0, "#101b3a");
    g.addColorStop(1, "#070a14");
    ctx.fillStyle = g;
    ctx.fillRect(0,0,W,H);

    // ground
    ctx.globalAlpha = 0.25;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, H-85, W, 85);
    ctx.globalAlpha = 1;

    // lanes
    ctx.globalAlpha = 0.18;
    ctx.strokeStyle = "#fff";
    ctx.lineWidth = 2;
    for (let y=70; y<H-90; y+=70){
      ctx.beginPath(); ctx.moveTo(30,y); ctx.lineTo(W-30,y); ctx.stroke();
    }
    ctx.globalAlpha = 1;

    // start/finish
    drawFlag(START.x-20, 40, "START");
    drawFlag(FINISH_X+10, 40, "FINISH");

    // "doll" / watcher as abstract shape
    drawWatcher(W-150, H/2);

    // light indicator
    drawLightBadge(18, 18, light);

    // player
    drawPlayer(p.x, p.y, p.r);

    // overlay text
    if (state === "start") overlay("Red Light / Green Light", "Space — бастау. GREEN кезінде жүр, RED кезінде тоқта.");
    if (state === "lose") overlay("Ұтылдың 💥", "RED кезінде қозғалып қойдың. R — қайта бастау");
    if (state === "win") overlay("Жеңіс! 🏁", "Мәреге жеттің. R — қайта ойнау");

    t += 1/60;
  }

  function drawLightBadge(x,y,mode){
    ctx.save();
    ctx.globalAlpha = 0.92;
    ctx.fillStyle = "rgba(255,255,255,.08)";
    roundRect(x,y,170,54,14,true,false);
    ctx.strokeStyle = "rgba(255,255,255,.18)";
    ctx.lineWidth = 2;
    roundRect(x,y,170,54,14,false,true);

    // dot
    ctx.fillStyle = (mode==="green") ? "rgba(80,240,170,.95)" : "rgba(255,90,120,.95)";
    ctx.beginPath(); ctx.arc(x+26,y+27,10,0,Math.PI*2); ctx.fill();

    ctx.fillStyle = "rgba(231,236,255,.95)";
    ctx.font = "900 16px system-ui,Segoe UI,Arial";
    ctx.fillText(mode.toUpperCase(), x+48, y+33);
    ctx.restore();
  }

  function drawPlayer(x,y,r){
    ctx.save();
    ctx.shadowBlur = 18;
    ctx.shadowColor = "rgba(106,167,255,.35)";
    ctx.fillStyle = "rgba(231,236,255,.92)";
    ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fill();
    ctx.shadowBlur = 0;
    ctx.strokeStyle = "rgba(0,0,0,.25)";
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.restore();
  }

  function drawWatcher(x,y){
    ctx.save();
    // body
    ctx.globalAlpha = 0.5;
    ctx.fillStyle = "rgba(255,255,255,.08)";
    roundRect(x-40,y-70,80,140,22,true,false);
    ctx.strokeStyle = "rgba(255,255,255,.14)";
    ctx.lineWidth = 2;
    roundRect(x-40,y-70,80,140,22,false,true);

    // eye
    ctx.globalAlpha = 0.9;
    ctx.fillStyle = (light==="green") ? "rgba(80,240,170,.75)" : "rgba(255,90,120,.75)";
    ctx.beginPath(); ctx.arc(x, y-18, 10, 0, Math.PI*2); ctx.fill();

    // scan line
    ctx.globalAlpha = 0.25;
    ctx.strokeStyle = "#fff";
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(x-26,y+10); ctx.lineTo(x+26,y+10); ctx.stroke();
    ctx.restore();
  }

  function drawFlag(x,y,label){
    ctx.save();
    ctx.globalAlpha = 0.85;
    ctx.strokeStyle = "rgba(255,255,255,.25)";
    ctx.lineWidth = 3;
    ctx.beginPath(); ctx.moveTo(x,y); ctx.lineTo(x,y+70); ctx.stroke();
    ctx.fillStyle = "rgba(255,255,255,.12)";
    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(x+56, y+10);
    ctx.lineTo(x, y+22);
    ctx.closePath();
    ctx.fill();
    ctx.fillStyle = "rgba(231,236,255,.8)";
    ctx.font = "700 12px system-ui,Segoe UI,Arial";
    ctx.fillText(label, x+6, y+18);
    ctx.restore();
  }

  function overlay(title, subtitle){
    ctx.save();
    ctx.fillStyle = "rgba(0,0,0,.45)";
    ctx.fillRect(0,0,W,H);
    ctx.fillStyle = "rgba(231,236,255,.95)";
    ctx.font = "900 34px system-ui,Segoe UI,Arial";
    ctx.textAlign = "center";
    ctx.fillText(title, W/2, H/2 - 16);
    ctx.fillStyle = "rgba(170,182,230,.95)";
    ctx.font = "16px system-ui,Segoe UI,Arial";
    ctx.fillText(subtitle, W/2, H/2 + 18);
    ctx.textAlign = "left";
    ctx.restore();
  }

  function roundRect(x,y,w,h,r,fill,stroke){
    const rr = Math.min(r, w/2, h/2);
    ctx.beginPath();
    ctx.moveTo(x+rr,y);
    ctx.arcTo(x+w,y, x+w,y+h, rr);
    ctx.arcTo(x+w,y+h, x,y+h, rr);
    ctx.arcTo(x,y+h, x,y, rr);
    ctx.arcTo(x,y, x+w,y, rr);
    ctx.closePath();
    if (fill) ctx.fill();
    if (stroke) ctx.stroke();
  }

  let last = performance.now();
  function loop(now){
    const dt = Math.min(0.03, (now-last)/1000);
    last = now;

    if (state === "play") update(dt);
    draw();
    requestAnimationFrame(loop);
  }

  reset();
  requestAnimationFrame(loop);
})();
</script>
</body>
</html>
